//
// Do any local configuration here
//

// Forward zone 
zone "home.wetheringtontelecom.com" IN { 
  // Primary DNS
  type master;

  // Forward lookup file
  file "/etc/bind/home-wetheringtontelecom-com.zone";

  allow-update { none; };

  // Allow Transfer of this zone from this master server
  allow-transfer  { 10.0.10.107; }; 

  // Notify slave of changes in this zone
  also-notify { 10.0.10.107; };
};
